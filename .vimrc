" make vim work properly
set nocompatible

" normal mode bind to jj 
inoremap jj <Esc>

" syntax highlighting
syntax on

" filetype detection
filetype on

" normal and relative line numbers
set number relativenumber

" 2 space tabs
set expandtab tabstop=2 shiftwidth=2

" ignore casing with search
set ignorecase

" show current mode and last command at bottom of screen
set showmode showcmd

" prevent cursor from getting within x lines of the top or bottom
set scrolloff=5

